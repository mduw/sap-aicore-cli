{
  "name": "sap-aicore-cli",
  "version": "0.0.0",
  "description": "CLI for SAP AI Core - manage deployments, executions, configurations, prompt templates, secrets, and AI resources from the terminal",
  "type": "module",
  "bin": {
    "saic-cli": "./bin/index.js"
  },
  "files": [
    "bin",
    "lib",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs && node postbuild.mjs && tsc --emitDeclarationOnly",
    "clean": "rm -rf lib",
    "prebuild": "npm run clean",
    "start": "node lib/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "install-global": "npm run build && npm link",
    "uninstall-global": "npm unlink -g sap-ai-core-cli"
  },
  "keywords": [
    "sap",
    "ai core",
    "sap ai core",
    "cli",
    "prompt registry",
    "deployments",
    "executions",
    "configurations",
    "secrets",
    "foundation models",
    "generative ai",
    "saic-cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mduw/sap-aicore-cli"
  },
  "homepage": "https://github.com/mduw/sap-aicore-cli#readme",
  "bugs": {
    "url": "https://github.com/mduw/sap-aicore-cli/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@sap-ai-sdk/ai-api": "^2.8.0",
    "@sap-ai-sdk/prompt-registry": "^2.8.0",
    "@sap/cds": "^9.0.0",
    "chalk": "^5.6.2",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.15.0",
    "@types/node": "^22.19.15",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "cds": {
    "requires": {
      "aicore": {
        "kind": "rest",
        "vcap": {
          "label": "aicore"
        }
      }
    }
  }
}
